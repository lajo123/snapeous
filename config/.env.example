# SpotSEO - Configuration
# Copiez ce fichier en .env et remplissez les valeurs

# OpenRouter API (pour l'analyse IA via Kimi K2.5)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=moonshotai/kimi-k2.5

# Decodo Smart Proxy (pour le scraping Google)
DECODO_PROXY_HOST=gate.decodo.com
DECODO_PROXY_PORT=7000
DECODO_PROXY_USER=your_username
DECODO_PROXY_PASS=your_password

# SpeedyIndex API (vérification indexation Google)
SPEEDYINDEX_API_KEY=your_speedyindex_api_key

# DomDetailer API (métriques de domaine)
DOMDETAILER_API_KEY=your_domdetailer_api_key

# Base de données SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/spotseo.db

# Sécurité
APP_SECRET_KEY=change-this-to-a-random-secret-key

# Mode debug
DEBUG=true

# Paramètres SERP Scraping
SERP_DELAY_MIN=2.0
SERP_DELAY_MAX=6.0
MAX_CONCURRENT_SCRAPES=3
