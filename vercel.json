{
  "framework": null,
  "buildCommand": "cd frontend && npm install && npm run build && mv dist/index.html dist/app.html && cp ../landing.html dist/index.html",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(login|dashboard|projects|settings)(.*)", "destination": "/app.html" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}
